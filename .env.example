# App
APP_NAME=Bingasys Core
BACKEND_URL=http://127.0.0.1:8000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Auth
AUTH_SECRET_KEY=change-this-development-secret-before-production
AUTH_TOKEN_EXPIRE_MINUTES=1440
PASSWORD_RESET_EXPIRE_MINUTES=30

# SMTP is optional in local development. If SMTP_HOST is empty, reset links are logged.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@bingasys.local

# Postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bingasys

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TEMPERATURE=0.4
GEMINI_MAX_OUTPUT_TOKENS=512

# Shopify OAuth. For local OAuth testing, replace BACKEND_URL and SHOPIFY_REDIRECT_URI with your ngrok URL.
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_SCOPES=read_products,read_orders,write_orders,read_inventory,write_inventory,read_locations
SHOPIFY_REDIRECT_URI=http://127.0.0.1:8000/api/integrations/shopify/oauth/callback
SHOPIFY_OAUTH_STATE_EXPIRE_MINUTES=10
SHOPIFY_API_VERSION=2025-10
SHOPIFY_PRODUCT_CACHE_TTL_SECONDS=900
# Max image-bearing products compared against a buyer's photo. Higher = better
# recall for catalogs without matching title keywords, at more vision API calls.
SHOPIFY_IMAGE_MATCH_CATALOG_LIMIT=120

# Meta OAuth. For local OAuth testing, replace BACKEND_URL and META_REDIRECT_URI with your ngrok URL.
META_APP_ID=
META_APP_SECRET=
META_GRAPH_API_VERSION=v21.0
META_SCOPES=pages_show_list,pages_messaging,pages_manage_metadata,business_management
META_REDIRECT_URI=https://stardust-deviation-spring.ngrok-free.dev/api/integrations/meta/oauth/callback
META_OAUTH_STATE_EXPIRE_MINUTES=10
# Seconds to wait for more events from the same buyer before replying. Facebook
# delivers a caption and its image as separate events; this merges them into one
# reply. Set to 0 to reply to each event immediately.
META_MESSAGE_DEBOUNCE_SECONDS=2.5
